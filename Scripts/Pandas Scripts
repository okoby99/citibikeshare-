import pandas as pd
import os
    # Folder Path
folder_path = r"C:\Users\okoby\Downloads\Data Analysis dataset Citibike"
csv_files = [f for f in os.listdir(folder_path) if f.endswith('.csv')]

selected_columns = [
    'usertype',
    'start_time',
    'end_time',
    'ride_length',
    'day_of_week',
    'from_station_name',
    'to_station_name'
]

df_list = []

for file in csv_files:
    file_path = os.path.join(folder_path, file)
    print(f" Processing: {file}")
    
    try:
        # Use low_memory=False to prevent dtype issues
        df = pd.read_csv(file_path, low_memory=False)
        
        # Standardize column names (lowercase, strip spaces)
        df.columns = df.columns.str.strip().str.lower().str.replace(' ', '_')
        
        # Add any missing selected columns as None
        for col in selected_columns:
            if col not in df.columns:
                df[col] = None
        
        # Keep only the selected columns in order
        df = df[selected_columns]
        
        # Standardize usertype values
        df['usertype'] = df['usertype'].replace({
            'Subscriber': 'Member',
            'Customer': 'Casual'
        })
        
        df_list.append(df)
        print(f" {file}: {len(df)} rows added")
    
    except Exception as e:
        print(f" Error processing {file}: {e}")

# Merge all files
merged_df = pd.concat(df_list, ignore_index=True)

# Remove rows with nulls in any selected column
merged_df = merged_df.dropna(subset=selected_columns)

# Save final cleaned merged file
output_path = r"C:\Users\okoby\Downloads\cleaned_merged_data.csv"
merged_df.to_csv(output_path, index=False)

print(f"\n🎉 SUCCESS: All files merged! Total rows after cleaning: {len(merged_df)}")
